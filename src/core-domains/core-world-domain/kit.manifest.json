{
  "id": "core-world-domain",
  "version": "0.2.0",
  "stability": "experimental-core",
  "entry": "./index.js",
  "api": "coreWorld",
  "owns": [
    "world identity",
    "world partitions",
    "world cells",
    "world surfaces",
    "world effect references",
    "world lifecycle coordination",
    "world composition",
    "world snapshots"
  ],
  "doesNotOwn": [
    "terrain generation",
    "provider implementation state",
    "renderer implementation",
    "GPU resources",
    "physics resolution",
    "game-specific content"
  ],
  "kits": [
    "world-cell-kit",
    "world-partition-kit",
    "world-surface-kit",
    "world-effect-provider-kit",
    "world-builder-runtime-kit"
  ],
  "providerLifecycle": [
    "prepareCell",
    "updateCell",
    "releaseCell",
    "getEffectDescriptor",
    "snapshot",
    "restoreSnapshot",
    "reset"
  ],
  "partitions": ["uniform-grid", "quadtree"],
  "surfaces": ["flat", "curved-horizon"],
  "state": "resource-backed portable coordination metadata",
  "heavyState": "provider-owned"
}
